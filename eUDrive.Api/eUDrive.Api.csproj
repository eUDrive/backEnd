      <PrivateAssets>all</PrivateAssets>
      <IncludeAssets>runtime; build; native; contentfiles; analyzers; buildtransitive</IncludeAssets>
    </PackageReference>
    <PackageReference Include="Swashbuckle.AspNetCore" Version="10.1.4" />
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="..\eUDrive.BusinessLogic\eUDrive.BusinessLogic.csproj" />
    <ProjectReference Include="..\eUDrive.Domain\eUDrive.Domains.csproj" />
  </ItemGroup>

</Project>
